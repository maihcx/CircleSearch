<Window x:Class="CircleSearch.Overlay.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:CircleSearch.Overlay.Utils"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Left="0" Top="0"
        Cursor="Cross"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <!-- Full-screen dimming overlay -->
        <Rectangle x:Name="DimOverlay"
                   Fill="#88000000"
                   IsHitTestVisible="False"
                   Opacity="0">
            <Rectangle.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="DimOverlay"
                                             Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Rectangle.Triggers>
        </Rectangle>

        <!-- Hint text shown before selecting -->
        <StackPanel x:Name="HintPanel"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    IsHitTestVisible="False">
            <TextBlock Style="{StaticResource HintText}" FontSize="20" Margin="0,0,0,12">
                <Run Text="✦  "/>
                <Run Text="{utils:Localization overlay_draw_circle_title}"/>
                <Run Text="  ✦"/>
                <TextBlock.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="Black" Opacity="0.8"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Style="{StaticResource HintText}"
                       Text="{utils:Localization overlay_press_esc_title}"
                       FontSize="13" Opacity="0.6"/>
        </StackPanel>

        <!-- Selection canvas — handles mouse events -->
        <Canvas x:Name="DrawingCanvas"
                Background="Transparent"
                MouseDown="OnMouseDown"
                MouseMove="OnMouseMove"
                MouseUp="OnMouseUp">

            <!-- Dark mask: Top -->
            <Rectangle x:Name="MaskTop"
                       Fill="#88000000"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>

            <!-- Dark mask: Bottom -->
            <Rectangle x:Name="MaskBottom"
                       Fill="#88000000"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>

            <!-- Dark mask: Left -->
            <Rectangle x:Name="MaskLeft"
                       Fill="#88000000"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>

            <!-- Dark mask: Right -->
            <Rectangle x:Name="MaskRight"
                       Fill="#88000000"
                       IsHitTestVisible="False"
                       Visibility="Collapsed"/>

            <!-- The selected region (clear / bright) -->
            <Rectangle x:Name="SelectionRect"
                       Stroke="#FF4FC3F7"
                       StrokeThickness="2"
                       Fill="Transparent"
                       Visibility="Collapsed"
                       IsHitTestVisible="False"/>

            <!-- Size label shown while dragging -->
            <Border x:Name="SizeLabel"
                    Background="#CC1E1E2E"
                    CornerRadius="4"
                    Padding="8,3"
                    Visibility="Collapsed"
                    IsHitTestVisible="False">
                <TextBlock x:Name="SizeLabelText"
                           Foreground="White"
                           FontSize="11"
                           FontFamily="Consolas"/>
            </Border>
        </Canvas>

        <!-- Crosshair lines that follow cursor before drag -->
        <Line x:Name="CrosshairH"
              Stroke="#66FFFFFF" StrokeThickness="1"
              X1="0" X2="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
              IsHitTestVisible="False"
              Visibility="Collapsed">
            <Line.RenderTransform>
                <TranslateTransform x:Name="CrosshairHT"/>
            </Line.RenderTransform>
        </Line>
        <Line x:Name="CrosshairV"
              Stroke="#66FFFFFF" StrokeThickness="1"
              Y1="0" Y2="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"
              IsHitTestVisible="False"
              Visibility="Collapsed">
            <Line.RenderTransform>
                <TranslateTransform x:Name="CrosshairVT"/>
            </Line.RenderTransform>
        </Line>

        <!-- Processing indicator -->
        <Border x:Name="ProcessingPanel"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,40"
                Background="#CC1E1E2E"
                CornerRadius="20"
                Padding="20,10"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" Fill="#4FC3F7" x:Name="Dot1" Margin="0,0,6,0"/>
                <Ellipse Width="8" Height="8" Fill="#4FC3F7" x:Name="Dot2" Margin="0,0,6,0"/>
                <Ellipse Width="8" Height="8" Fill="#4FC3F7" x:Name="Dot3" Margin="0,0,10,0"/>
                <TextBlock Foreground="White" VerticalAlignment="Center" FontSize="13">
                    <Run Text="{utils:Localization overlay_processing_title}"/><Run Text="..."/>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
