<Window x:Class="CircleSearch.Overlay.Views.ActionPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:utils="clr-namespace:CircleSearch.Overlay.Utils"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        IsHitTestVisible="True">

    <Window.Resources>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#CC1E1E2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF2D2D44"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#88FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF3D3D55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Padding="8"
            Background="#DD0F0F1A"
            BorderBrush="#33FFFFFF"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Color="Black" Opacity="0.6"/>
        </Border.Effect>
        <StackPanel Orientation="Vertical" MinWidth="160">
            <!-- OCR Text preview (shows when text detected) -->
            <Border x:Name="OcrPreviewBorder"
                    Background="#22FFFFFF" CornerRadius="8" Padding="10,8" Margin="4,4,4,2">
                <StackPanel>
                    <TextBlock Foreground="#AAFFFFFF" FontSize="11" Margin="0,0,0,4">
                        <Run Text="📄"/>
                        <Run Text="{utils:Localization action_doc_id_title}"/><Run Text=":"/>
                    </TextBlock>
                    <TextBox x:Name="OcrPreviewText"
                         Background="Transparent"
                         Foreground="#AAFFFFFF"
                         CaretBrush="White"
                         BorderThickness="0"
                         FontSize="12"
                         TextWrapping="Wrap"
                         MaxWidth="280"
                         MaxHeight="80"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"/>
                </StackPanel>
            </Border>

            <!-- Action buttons -->
            <WrapPanel Margin="0,2" MaxWidth="340">
                <Button x:Name="BtnSearch" Style="{StaticResource ActionBtn}"
                        ToolTip="{utils:Localization action_search_tooltip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" FontSize="15" Margin="0,0,6,0"/>
                        <TextBlock Text="{utils:Localization action_search_title}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSearchImage" Style="{StaticResource ActionBtn}"
                        ToolTip="{utils:Localization action_image_search_tooltip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🖼️" FontSize="15" Margin="0,0,6,0"/>
                        <TextBlock Text="{utils:Localization action_image_search_title}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnOcr" Style="{StaticResource ActionBtn}"
                        ToolTip="{utils:Localization action_text_copy_tooltip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="15" Margin="0,0,6,0"/>
                        <TextBlock Text="{utils:Localization action_text_copy_title}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnTranslate" Style="{StaticResource ActionBtn}"
                        ToolTip="{utils:Localization action_translate_tooltip}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🌐" FontSize="15" Margin="0,0,6,0"/>
                        <TextBlock Text="{utils:Localization action_translate_title}"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnClose" Style="{StaticResource ActionBtn}"
                        ToolTip="{utils:Localization action_close_tooltip}">
                    <TextBlock Text="✕" FontSize="14"/>
                </Button>
            </WrapPanel>

            <!-- Status bar -->
            <TextBlock x:Name="StatusText" Foreground="#77FFFFFF" FontSize="11"
                       HorizontalAlignment="Center" Margin="4,4,4,6" Visibility="Collapsed"/>
        </StackPanel>
    </Border>
</Window>
