<Page
    x:Class="CircleSearch.Views.Pages.ConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:CircleSearch.Views.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="ConfigPage"
    d:DataContext="{d:DesignInstance local:ConfigPage,
                                        IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    xmlns:utils="clr-namespace:CircleSearch.Utils"
    mc:Ignorable="d"
    ScrollViewer.CanContentScroll="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="1" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource ControlElevationBorderBrush}"/>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,8">
            <StackPanel>

                <!-- Header card -->
                <ui:Card Margin="0,8,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Search24" FontSize="32"
                                   Margin="0,0,16,0" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{utils:Localization page_config_cts_des_title}"
                                   FontSize="18" FontWeight="SemiBold"/>
                            <TextBlock Text="{utils:Localization page_config_cts_des_summary}"
                                   Opacity="0.6" FontSize="13" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Grid.Column="2" VerticalAlignment="Center"
                            Background="{Binding ViewModel.IsDaemonRunning, Converter={StaticResource BoolToGreenRedBrush}}"
                            CornerRadius="12" Padding="10,4">
                            <TextBlock Text="{Binding ViewModel.IsDaemonRunning, Converter={StaticResource BoolToStatusText}}"
                                   FontSize="12" Foreground="White"/>
                        </Border>
                    </Grid>
                </ui:Card>

                <!-- Hotkey Section -->
                <ui:CardExpander IsExpanded="True" Margin="0,0,0,8">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Keyboard24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{utils:Localization page_config_cts_hotkey_title}" FontWeight="SemiBold"/>
                                <TextBlock Opacity="0.6" FontSize="12">
                                    <Run Text="{utils:Localization page_config_cts_hotkey_context}"/><Run Text=":"/>
                                    <Run Text="{Binding ViewModel.HotkeyDisplay}"/> 
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>
                    <StackPanel Margin="8,4">
                        <TextBlock Opacity="0.7" Margin="0,0,0,8">
                            <Run Text="{utils:Localization page_config_cts_hotkey_set_title}"/><Run Text=":"/>
                        </TextBlock>
                        <WrapPanel Orientation="Horizontal">
                            <ui:ToggleSwitch Content="Ctrl"  IsChecked="{Binding ViewModel.CtrlKey}"  Margin="0,0,16,8"/>
                            <ui:ToggleSwitch Content="Win ⊞" IsChecked="{Binding ViewModel.WinKey}"   Margin="0,0,16,8"/>
                            <ui:ToggleSwitch Content="Alt"   IsChecked="{Binding ViewModel.AltKey}"   Margin="0,0,16,8"/>
                            <ui:ToggleSwitch Content="Shift" IsChecked="{Binding ViewModel.ShiftKey}" Margin="0,0,16,8"/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,4,0,0">
                            <TextBlock VerticalAlignment="Center" Opacity="0.7" Margin="0,0,10,0">
                                <Run Text="{utils:Localization page_config_cts_key_title}"/><Run Text=":"/>
                            </TextBlock>
                            <ComboBox Width="120" Margin="0,0,12,0"
                                  ItemsSource="{Binding ViewModel.AvailableKeys}"
                                  SelectedItem="{Binding ViewModel.SelectedKey}"/>
                            <Border Background="#1AFFFFFF" CornerRadius="8" Padding="16,8"
                                BorderBrush="#33FFFFFF" BorderThickness="1">
                                <TextBlock Text="{Binding ViewModel.HotkeyDisplay}"
                                       FontSize="14" FontWeight="Bold" FontFamily="Consolas"/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ui:CardExpander>

                <!-- Search Engine Section -->
                <ui:CardExpander IsExpanded="True" Margin="0,0,0,8">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="Globe24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{utils:Localization page_config_search_engine_title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{utils:Localization page_config_search_engine_summary}" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>
                    <StackPanel Margin="8,4">
                        <ComboBox Width="220" HorizontalAlignment="Left"
                              ItemsSource="{Binding ViewModel.SearchEngines}"
                              SelectedIndex="{Binding ViewModel.SelectedSearchEngine}"
                              DisplayMemberPath="Name"/>
                    </StackPanel>
                </ui:CardExpander>

                <!-- OCR Section -->
                <ui:CardExpander IsExpanded="True" Margin="0,0,0,8">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="ScanText24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{utils:Localization page_config_ocr_title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{utils:Localization page_config_ocr_summary}" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>
                    <StackPanel Margin="8,4">
                        <TextBlock Opacity="0.7" Margin="0,0,0,8">
                            <Run Text="{utils:Localization page_config_ocr_lang_title}"/><Run Text=":"/>
                        </TextBlock>
                        <ComboBox Width="240" HorizontalAlignment="Left" Margin="0,0,0,10"
                              ItemsSource="{Binding ViewModel.OcrLanguages}"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Code"
                              SelectedValue="{Binding ViewModel.SelectedOcrLanguage}"/>
                    </StackPanel>
                </ui:CardExpander>

                <!-- Appearance Section -->
                <ui:CardExpander Margin="0,0,0,8" Visibility="Collapsed">
                    <ui:CardExpander.Header>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Symbol="PaintBrush24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Giao diện Overlay" FontWeight="SemiBold"/>
                                <TextBlock Text="Tùy chỉnh độ mờ và màu sắc" Opacity="0.6" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander.Header>
                    <StackPanel Margin="8,4">
                        <TextBlock Text="{Binding ViewModel.OverlayOpacity, StringFormat='Độ mờ overlay: {0:P0}'}"
                               Opacity="0.7" Margin="0,0,0,6"/>
                        <Slider Minimum="0.3" Maximum="1.0" TickFrequency="0.05"
                            Value="{Binding ViewModel.OverlayOpacity}"
                            Width="300" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Màu nhấn:" VerticalAlignment="Center"
                                   Opacity="0.7" Margin="0,0,10,0"/>
                            <ui:TextBox Text="{Binding ViewModel.AccentColor}" Width="120"
                                    PlaceholderText="#4FC3F7" Margin="0,0,10,0"/>
                            <Border Width="32" Height="32" CornerRadius="6">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding ViewModel.AccentColor,
                                    Converter={StaticResource StringToColorConverter}}"/>
                                </Border.Background>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ui:CardExpander>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Padding="24,12" BorderThickness="0,1,0,0"
            BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding ViewModel.StatusMessage}"
                       VerticalAlignment="Center" Opacity="0.7" FontSize="12"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="{utils:Localization page_config_overay_try_title}"
                           Icon="{ui:SymbolIcon PlayCircle24}"
                           Appearance="Secondary" Margin="0,0,8,0"
                           Command="{Binding ViewModel.TestOverlayCommand}"/>
                    <ui:Button Content="{utils:Localization save_title}"
                           Icon="{ui:SymbolIcon Save24}"
                           Appearance="Primary"
                           Command="{Binding ViewModel.SaveSettingsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
